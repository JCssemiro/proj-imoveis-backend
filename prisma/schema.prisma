// ImobiConnect — parâmetros: PK codigo (int); entidades: UUID nativo; status lead = smallint ordenado; valores monetários Decimal

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum tipousuario {
  client
  broker
}

enum tiporemetente {
  client
  broker
}

// --- Parâmetros (PK = codigo inteiro de negócio) ---

model finalidadeuso {
  codigo Int     @id @map("codigo")
  nome   String  @db.VarChar(120)
  ativo  Boolean @default(true)

  tiposimovel tipoimovel[]
  interesses  interesseimovel[]

  @@index([ativo])
  @@map("finalidadeuso")
}

model finalidadecontratacao {
  codigo Int     @id @map("codigo")
  nome   String  @db.VarChar(120)
  ativo  Boolean @default(true)

  interesses interesseimovel[]

  @@index([ativo])
  @@map("finalidadecontratacao")
}

model tipoimovel {
  codigo                Int           @id @map("codigo")
  nome                  String        @db.VarChar(120)
  finalidadeusocodigo   Int           @map("finalidadeusocodigo")
  finalidadeuso         finalidadeuso @relation(fields: [finalidadeusocodigo], references: [codigo], onDelete: Restrict)
  ativo                 Boolean       @default(true)

  interesses interesseimovel[]

  @@index([ativo])
  @@index([finalidadeusocodigo])
  @@map("tipoimovel")
}

model mobilia {
  codigo Int     @id @map("codigo")
  nome   String  @db.VarChar(120)
  ativo  Boolean @default(true)

  interesses interesseimovel[]

  @@index([ativo])
  @@map("mobilia")
}

model urgencia {
  codigo Int     @id @map("codigo")
  nome   String  @db.VarChar(120)
  ativo  Boolean @default(true)

  interesses interesseimovel[]

  @@index([ativo])
  @@map("urgencia")
}

model plano {
  codigo      Int      @id @map("codigo")
  nome        String   @db.VarChar(120)
  precomensal Decimal  @default(0) @db.Decimal(14, 2)
  ativo       Boolean  @default(true)

  corretores usuario[]

  @@index([ativo])
  @@map("plano")
}

// --- Entidades (PK = UUID; expostos na API) ---

model usuario {
  id                  String      @id @default(uuid()) @db.Uuid
  nome                String      @db.VarChar(200)
  email               String      @unique @db.VarChar(320)
  telefone            String      @db.VarChar(30)
  senhahash           String      @db.VarChar(255)
  tipo                tipousuario
  creci               String?     @unique @db.VarChar(30)
  planocodigo         Int?        @map("planocodigo")
  plano               plano?      @relation(fields: [planocodigo], references: [codigo], onDelete: SetNull)
  ativoassinatura     Boolean?
  avatar              String?     @db.VarChar(2048)
  tokenresetarsenha   String?     @db.VarChar(128)
  expiraresetarsenha  DateTime?
  criadoem            DateTime    @default(now())
  atualizadoem        DateTime    @updatedAt

  interestsAsClient     interesseimovel[] @relation("ClientInterests")
  conversationsAsClient conversa[]        @relation("ClientConversations")
  conversationsAsBroker conversa[]        @relation("BrokerConversations")
  messagesSent          mensagem[]

  @@index([tipo])
  @@index([planocodigo])
  @@map("usuario")
}

model interesseimovel {
  id                          String                @id @default(uuid()) @db.Uuid
  clientid                    String                @map("clientid") @db.Uuid
  client                      usuario               @relation("ClientInterests", fields: [clientid], references: [id], onDelete: Cascade)
  finalidadecontratacaocodigo Int                   @map("finalidadecontratacaocodigo")
  finalidadecontratacao       finalidadecontratacao @relation(fields: [finalidadecontratacaocodigo], references: [codigo], onDelete: Restrict)
  finalidadeusocodigo         Int                   @map("finalidadeusocodigo")
  finalidadeuso               finalidadeuso         @relation(fields: [finalidadeusocodigo], references: [codigo], onDelete: Restrict)
  tipoimovelcodigo            Int                   @map("tipoimovelcodigo")
  tipoimovel                  tipoimovel            @relation(fields: [tipoimovelcodigo], references: [codigo], onDelete: Restrict)
  mobiliacodigo               Int                   @map("mobiliacodigo")
  mobilia                     mobilia               @relation(fields: [mobiliacodigo], references: [codigo], onDelete: Restrict)
  urgenciacodigo              Int                   @map("urgenciacodigo")
  urgencia                    urgencia              @relation(fields: [urgenciacodigo], references: [codigo], onDelete: Restrict)
  aceitafinanciamento         Boolean               @default(false)
  quartos                     Int[]                 @default([])
  suites                      Int[]                 @default([])
  metragem                    Int?
  minprice                    Decimal               @default(0) @db.Decimal(14, 2)
  maxprice                    Decimal               @default(0) @db.Decimal(14, 2)
  observacoes                 String                @default("") @db.VarChar(5000)
  status                      Int                   @default(1) @db.SmallInt
  ativo                       Boolean               @default(true)
  criadoem                    DateTime              @default(now())

  localizacoes localizacaointeresse[]
  conversas    conversa[]

  @@index([clientid])
  @@index([criadoem])
  @@index([ativo])
  @@index([clientid, ativo])
  @@index([tipoimovelcodigo])
  @@index([minprice, maxprice])
  @@index([finalidadecontratacaocodigo])
  @@index([finalidadeusocodigo])
  @@index([status])
  @@map("interesseimovel")
}

model localizacaointeresse {
  id                String          @id @default(uuid()) @db.Uuid
  interesseimovelid String          @map("interesseimovelid") @db.Uuid
  interesseimovel   interesseimovel @relation(fields: [interesseimovelid], references: [id], onDelete: Cascade)
  cep               String?         @db.VarChar(12)
  logradouro        String?         @db.VarChar(255)
  bairro            String?         @db.VarChar(120)
  cidade            String?         @db.VarChar(120)
  uf                String?         @db.Char(2)
  codibgecidade     String?         @db.VarChar(10)

  @@index([interesseimovelid])
  @@index([cep])
  @@index([codibgecidade])
  @@map("localizacaointeresse")
}

model conversa {
  id                String          @id @default(uuid()) @db.Uuid
  clientid          String          @map("clientid") @db.Uuid
  client            usuario         @relation("ClientConversations", fields: [clientid], references: [id], onDelete: Cascade)
  corretorid        String          @map("corretorid") @db.Uuid
  corretor          usuario         @relation("BrokerConversations", fields: [corretorid], references: [id], onDelete: Cascade)
  interesseimovelid String          @map("interesseimovelid") @db.Uuid
  interesseimovel   interesseimovel @relation(fields: [interesseimovelid], references: [id], onDelete: Cascade)
  resumointeresse   String          @map("resumointeresse") @db.VarChar(512)
  ativo             Boolean         @default(true)
  atualizadoem      DateTime        @updatedAt

  mensagens mensagem[]

  @@index([clientid])
  @@index([corretorid])
  @@index([interesseimovelid, ativo])
  @@index([corretorid, ativo])
  @@index([atualizadoem])
  @@map("conversa")
}

model mensagem {
  id            String        @id @default(uuid()) @db.Uuid
  conversaid    String        @map("conversaid") @db.Uuid
  conversa      conversa      @relation(fields: [conversaid], references: [id], onDelete: Cascade)
  remetenteid   String        @map("remetenteid") @db.Uuid
  remetente     usuario       @relation(fields: [remetenteid], references: [id], onDelete: Cascade)
  tiporemetente tiporemetente @map("tiporemetente")
  conteudo      String        @db.VarChar(4000)
  urlimagem     String?       @map("urlimagem") @db.VarChar(2048)
  criadoem      DateTime      @default(now())

  @@index([conversaid])
  @@index([criadoem])
  @@index([conversaid, criadoem])
  @@map("mensagem")
}
