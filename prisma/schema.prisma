// ImobiConnect - PostgreSQL + Prisma
// API-ARQ.md / API-BACKEND-SPEC.md
// Schema: nomes dos models em minúsculas (igual às tabelas no banco)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  client
  broker
}

enum LeadStatus {
  new
  contacted
  in_progress
  closed
}

enum SenderType {
  client
  broker
}

// =============================================================================
// Tabelas de parâmetros (parametrização: novos valores sem alterar schema)
// =============================================================================

model finalidade {
  id        String   @id @default(uuid())
  codigo    String   @unique
  label     String
  ativo     Boolean  @default(true)
  ordem     Int      @default(0)
  createdAt DateTime @default(now())

  interesses interesseimovel[]

  @@index([ativo, ordem])
  @@map("finalidade")
}

model tipoimovel {
  id        String   @id @default(uuid())
  codigo    String   @unique
  label     String
  ativo     Boolean  @default(true)
  ordem     Int      @default(0)
  createdAt DateTime @default(now())

  interesses interesseimovel[]

  @@index([ativo, ordem])
  @@map("tipoimovel")
}

model tipocasa {
  id        String   @id @default(uuid())
  codigo    String   @unique
  label     String
  ativo     Boolean  @default(true)
  ordem     Int      @default(0)
  createdAt DateTime @default(now())

  interesses interesseimovel[]

  @@index([ativo, ordem])
  @@map("tipocasa")
}

model compraoualuguel {
  id        String   @id @default(uuid())
  codigo    String   @unique
  label     String
  ativo     Boolean  @default(true)
  ordem     Int      @default(0)
  createdAt DateTime @default(now())

  interesses interesseimovel[]

  @@index([ativo, ordem])
  @@map("compraoualuguel")
}

model mobilia {
  id        String   @id @default(uuid())
  codigo    String   @unique
  label     String
  ativo     Boolean  @default(true)
  ordem     Int      @default(0)
  createdAt DateTime @default(now())

  interesses interesseimovel[]

  @@index([ativo, ordem])
  @@map("mobilia")
}

// =============================================================================
// usuario
// =============================================================================

model usuario {
  id                    String    @id @default(uuid())
  name                  String
  email                 String    @unique
  phone                 String
  passwordHash          String
  type                  UserType
  cpf                   String?
  creci                 String?
  subscriptionActive    Boolean?
  avatar                String?
  resetPasswordToken    String?
  resetPasswordExpires  DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  interestsAsClient     interesseimovel[]
  leadsAsBroker         prospecto[]
  conversationsAsClient conversa[]  @relation("ClientConversations")
  conversationsAsBroker conversa[]  @relation("BrokerConversations")
  messagesSent          mensagem[]

  @@index([type])
  @@map("usuario")
}

// =============================================================================
// interesseimovel (FKs para parâmetros, tipos numéricos para filtros/performance)
// =============================================================================

model interesseimovel {
  id                  String   @id @default(uuid())
  clientId            String
  client              usuario  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  locations           String[]
  compraOuAluguelId   String
  compraOuAluguel     compraoualuguel @relation(fields: [compraOuAluguelId], references: [id], onDelete: Restrict)
  finalidadeId        String
  finalidade          finalidade     @relation(fields: [finalidadeId], references: [id], onDelete: Restrict)
  tipoImovelId        String
  tipoImovel          tipoimovel     @relation(fields: [tipoImovelId], references: [id], onDelete: Restrict)
  tipoCasaId          String
  tipoCasa            tipocasa       @relation(fields: [tipoCasaId], references: [id], onDelete: Restrict)
  mobiliaId           String
  mobilia             mobilia        @relation(fields: [mobiliaId], references: [id], onDelete: Restrict)
  quartos             Int?           // NULL = indiferente
  suites              Int?
  metragemTerreno     Int?           // m²
  areaConstruida      Int?           // m²
  minPrice            Int            @default(0)
  maxPrice            Int            @default(0)
  features            String[]
  notes               String         @default("")
  isActive            Boolean        @default(true)
  createdAt           DateTime       @default(now())

  lead                prospecto?

  @@index([clientId])
  @@index([createdAt])
  @@index([isActive])
  @@index([clientId, isActive])
  @@index([finalidadeId, tipoImovelId])
  @@index([minPrice, maxPrice])
  @@map("interesseimovel")
}

model prospecto {
  id         String     @id @default(uuid())
  interestId String     @unique
  interest   interesseimovel @relation(fields: [interestId], references: [id], onDelete: Cascade)
  brokerId   String?
  broker     usuario?   @relation(fields: [brokerId], references: [id], onDelete: SetNull)
  status     LeadStatus @default(new)
  createdAt  DateTime   @default(now())

  conversation conversa?

  @@index([brokerId])
  @@index([status])
  @@index([createdAt])
  @@index([brokerId, status])
  @@map("prospecto")
}

model conversa {
  id                      String    @id @default(uuid())
  clientId                String
  client                  usuario   @relation("ClientConversations", fields: [clientId], references: [id], onDelete: Cascade)
  brokerId                String
  broker                  usuario   @relation("BrokerConversations", fields: [brokerId], references: [id], onDelete: Cascade)
  leadId                  String    @unique
  lead                    prospecto @relation(fields: [leadId], references: [id], onDelete: Cascade)
  propertyInterestSummary String
  updatedAt               DateTime  @updatedAt

  messages mensagem[]

  @@index([clientId])
  @@index([brokerId])
  @@index([updatedAt])
  @@map("conversa")
}

model mensagem {
  id             String     @id @default(uuid())
  conversationId String
  conversation   conversa   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         usuario    @relation(fields: [senderId], references: [id], onDelete: Cascade)
  senderType     SenderType
  content        String
  imageUrl       String?
  createdAt      DateTime   @default(now())

  @@index([conversationId])
  @@index([createdAt])
  @@index([conversationId, createdAt])
  @@map("mensagem")
}
