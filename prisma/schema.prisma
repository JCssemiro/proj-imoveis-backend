// ImobiConnect - PostgreSQL + Prisma
// Schema alinhado à migration: tabelas/colunas em minúsculas, enum compraoualuguel,
// feature/localizacao parametrizados, plano corretores

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum tipousuario {
  client
  broker
}

enum statuslead {
  new
  contacted
  in_progress
  closed
}

enum tiporemetente {
  client
  broker
}

enum compraoualuguel {
  compra
  aluguel
}

// =============================================================================
// Parâmetros (cadastro sem alterar schema)
// =============================================================================

model finalidade {
  id        String   @id @default(uuid())
  codigo    String   @unique
  label     String
  ativo     Boolean  @default(true)
  ordem     Int      @default(0)
  criadoem  DateTime @default(now())

  interesses interesseimovel[]

  @@index([ativo, ordem])
  @@map("finalidade")
}

model tipoimovel {
  id       String   @id @default(uuid())
  codigo   String   @unique
  label    String
  ativo    Boolean  @default(true)
  ordem    Int      @default(0)
  criadoem DateTime @default(now())

  interesses interesseimovel[]

  @@index([ativo, ordem])
  @@map("tipoimovel")
}

model tipocasa {
  id       String   @id @default(uuid())
  codigo   String   @unique
  label    String
  ativo    Boolean  @default(true)
  ordem    Int      @default(0)
  criadoem DateTime @default(now())

  interesses interesseimovel[]

  @@index([ativo, ordem])
  @@map("tipocasa")
}

model mobilia {
  id       String   @id @default(uuid())
  codigo   String   @unique
  label    String
  ativo    Boolean  @default(true)
  ordem    Int      @default(0)
  criadoem DateTime @default(now())

  interesses interesseimovel[]

  @@index([ativo, ordem])
  @@map("mobilia")
}

model feature {
  id       String   @id @default(uuid())
  codigo   String   @unique
  label    String
  ativo    Boolean  @default(true)
  ordem    Int      @default(0)
  criadoem DateTime @default(now())

  interesses interesseimovelfeature[]

  @@index([ativo, ordem])
  @@map("feature")
}

model plano {
  id       String   @id @default(uuid())
  codigo   String   @unique
  label    String
  ativo    Boolean  @default(true)
  ordem    Int      @default(0)
  criadoem DateTime @default(now())

  corretores usuario[]

  @@index([ativo, ordem])
  @@map("plano")
}

// =============================================================================
// usuario
// =============================================================================

model usuario {
  id                   String    @id @default(uuid())
  nome                 String
  email                String    @unique
  telefone             String
  senhahash            String
  tipo                 tipousuario
  cpf                  String?   @unique
  creci                String?   @unique
  planoid              String?
  plano                plano?    @relation(fields: [planoid], references: [id], onDelete: SetNull)
  ativoassinatura      Boolean?
  avatar               String?
  tokenresetarsenha    String?
  expiraresetarsenha   DateTime?
  criadoem             DateTime  @default(now())
  atualizadoem         DateTime  @updatedAt

  interestsAsClient    interesseimovel[]
  leadsAsBroker        prospecto[]
  conversationsAsClient conversa[]  @relation("ClientConversations")
  conversationsAsBroker conversa[]  @relation("BrokerConversations")
  messagesSent         mensagem[]

  @@index([tipo])
  @@index([planoid])
  @@map("usuario")
}

// =============================================================================
// interesseimovel
// =============================================================================

model interesseimovel {
  id               String           @id @default(uuid())
  clientid         String
  client           usuario          @relation(fields: [clientid], references: [id], onDelete: Cascade)
  compraoualuguel  compraoualuguel
  finalidadeid     String
  finalidade       finalidade       @relation(fields: [finalidadeid], references: [id], onDelete: Restrict)
  tipoimovelid     String
  tipoimovel       tipoimovel       @relation(fields: [tipoimovelid], references: [id], onDelete: Restrict)
  tipocasaid       String
  tipocasa         tipocasa         @relation(fields: [tipocasaid], references: [id], onDelete: Restrict)
  mobiliaid        String
  mobilia          mobilia          @relation(fields: [mobiliaid], references: [id], onDelete: Restrict)
  quartos          Int?
  suites           Int?
  metragemterreno  Int?
  areaconstruida   Int?
  minprice         Int              @default(0)
  maxprice         Int              @default(0)
  observacoes      String           @default("")
  ativo            Boolean          @default(true)
  criadoem         DateTime         @default(now())

  localizacoes     localizacaointeresse[]
  features         interesseimovelfeature[]
  lead             prospecto?

  @@index([clientid])
  @@index([criadoem])
  @@index([ativo])
  @@index([clientid, ativo])
  @@index([finalidadeid, tipoimovelid])
  @@index([minprice, maxprice])
  @@index([compraoualuguel])
  @@map("interesseimovel")
}

model localizacaointeresse {
  id                String          @id @default(uuid())
  interesseimovelid String
  interesseimovel   interesseimovel @relation(fields: [interesseimovelid], references: [id], onDelete: Cascade)
  cep               String?
  municipiocodibge   String?
  bairro            String?

  @@index([interesseimovelid])
  @@index([cep])
  @@index([municipiocodibge])
  @@map("localizacaointeresse")
}

model interesseimovelfeature {
  interesseimovelid String
  interesseimovel   interesseimovel @relation(fields: [interesseimovelid], references: [id], onDelete: Cascade)
  featureid         String
  feature           feature         @relation(fields: [featureid], references: [id], onDelete: Restrict)

  @@id([interesseimovelid, featureid])
  @@index([featureid])
  @@map("interesseimovelfeature")
}

model prospecto {
  id                  String          @id @default(uuid())
  interesseimovelid   String          @unique
  interesse           interesseimovel @relation(fields: [interesseimovelid], references: [id], onDelete: Cascade)
  corretorid          String?
  corretor            usuario?        @relation(fields: [corretorid], references: [id], onDelete: SetNull)
  status              statuslead      @default(new)
  criadoem            DateTime        @default(now())

  conversas           conversa[]

  @@index([corretorid])
  @@index([status])
  @@index([criadoem])
  @@index([corretorid, status])
  @@map("prospecto")
}

model conversa {
  id               String    @id @default(uuid())
  clientid         String
  client           usuario   @relation("ClientConversations", fields: [clientid], references: [id], onDelete: Cascade)
  corretorid       String
  corretor         usuario   @relation("BrokerConversations", fields: [corretorid], references: [id], onDelete: Cascade)
  leadid           String
  lead             prospecto @relation(fields: [leadid], references: [id], onDelete: Cascade)
  resumointeresse  String
  ativo            Boolean   @default(true)
  atualizadoem     DateTime  @updatedAt

  mensagens mensagem[]

  @@index([clientid])
  @@index([corretorid])
  @@index([leadid, ativo])
  @@index([corretorid, ativo])
  @@index([atualizadoem])
  @@map("conversa")
}

model mensagem {
  id             String       @id @default(uuid())
  conversaid     String
  conversa       conversa     @relation(fields: [conversaid], references: [id], onDelete: Cascade)
  remetenteid    String
  remetente      usuario      @relation(fields: [remetenteid], references: [id], onDelete: Cascade)
  tiporemetente  tiporemetente
  conteudo       String
  urlimagem      String?
  criadoem       DateTime     @default(now())

  @@index([conversaid])
  @@index([criadoem])
  @@index([conversaid, criadoem])
  @@map("mensagem")
}
